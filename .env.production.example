# =============================================================================
# Vercel Production Environment Variables
# Add these in: Vercel Dashboard → Project → Settings → Environment Variables
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://usedcarsdoctor.com
NEXT_PUBLIC_API_URL=/api

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:...@...neon.tech/neondb?sslmode=require

# ── Auth (JWT — stateless, no NextAuth) ──────────────────────────────────────
JWT_SECRET=replace-with-a-64-byte-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_EMAILS=admin@example.com

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Stripe (required only if payments are enabled) ───────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── CarVertical (set CARVERTICAL_USE_MOCK=true to skip real calls) ────────────
CARVERTICAL_API_KEY=your-carvertical-api-key
CARVERTICAL_BASE_URL=https://api.carvertical.com/v1
CARVERTICAL_USE_MOCK=true

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_REALTIME_MESSAGING=false
FEATURE_AI_DEEP_SCAN=false
